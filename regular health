<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smallville Health Fortress</title>
  <style>
    :root { --accent: #ff3333; --text: #ff6666; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Segoe UI', sans-serif; background: #000000; color: var(--text); margin: 0; padding: 0; }
    header { background: linear-gradient(rgba(0,0,0,0.9), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1518709268805-4e9042af2176') center/cover; height: 450px; display: flex; align-items: center; justify-content: center; border-bottom: 8px solid var(--accent); }
    h1 { font-size: 4.5rem; color: var(--accent); text-shadow: 0 0 35px #ff0000; letter-spacing: 8px; }
    nav { background: #1a1a1a; padding: 20px; text-align: center; position: sticky; top: 0; z-index: 100; border-bottom: 3px solid var(--accent); }
    nav a { color: var(--text); margin: 0 18px; text-decoration: none; font-weight: bold; font-size: 1.2rem; transition: all 0.3s; }
    nav a:hover { color: var(--accent); transform: scale(1.08); }
    section { padding: 100px 20px 80px 20px; max-width: 1200px; margin: 0 auto; }
    h2 { color: var(--accent); text-align: center; margin-bottom: 40px; text-shadow: 0 0 20px #ff0000; }
    .card { background: rgba(20, 20, 20, 0.98); border: 2px solid var(--accent); border-radius: 15px; padding: 25px; margin: 25px 0; box-shadow: 0 0 30px rgba(255, 51, 51, 0.5); }
    .muscle-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 25px; }
    .exercise { background: #1a1a1a; padding: 20px; border-radius: 12px; text-align: center; border: 1px solid var(--accent); }
    textarea { width: 100%; resize: vertical; min-height: 130px; }
    button { background: var(--accent); color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; }
    button:hover { background: #ff5555; }
  </style>
</head>
<body>

  <header><h1>SMALLVILLE HEALTH FORTRESS</h1></header>

  <nav>
    <a href="#nutricao">🥗 Alimentação</a>
    <a href="#exercicios">💪 Exercícios</a>
    <a href="#calculadora">🧮 Calculadora IA</a>
    <a href="#plano">📅 Plano 12 Semanas</a>
    <a href="#clark">🦸 Clark Kent Mode</a>
  </nav>

  <!-- ALIMENTAÇÃO - MUITAS RECEITAS -->
  <section id="nutricao">
    <h2>🥗 Enciclopédia de Receitas</h2>

    <div class="card">
      <h3>🔋 Pequeno Almoço</h3>
      <p><strong>Super-Homem:</strong> 6 claras + 2 ovos inteiros, 80g aveia, 2 bananas, 2 colheres pasta de amendoim</p>
      <p><strong>Macros:</strong> ~680 kcal | 48P | 75C | 22G</p>
      <h4>Modo de Preparo:</h4>
      <ol><li>Cozinha a aveia. <li>Faz ovos mexidos. <li>Adiciona banana e pasta de amendoim por cima.</li></ol>
    </div>

    <div class="card">
      <h3>🌾 Almoço</h3>
      <p><strong>Fazendeiro Clássico:</strong> 200g arroz integral, 150g feijão, 200g frango grelhado, legumes (brócolis, cenoura, espinafre), ½ abacate</p>
      <p><strong>Macros:</strong> ~750 kcal | 55P | 90C | 18G</p>
      <h4>Modo de Preparo:</h4>
      <ol><li>Cozinha arroz e feijão. <li>Grelha o frango. <li>Salteia os legumes e monta o prato.</li></ol>
    </div>

    <div class="card">
      <h3>🍣 Jantar</h3>
      <p><strong>Salmão de Recuperação:</strong> 200g salmão, batata doce, salada verde com azeite</p>
      <p><strong>Macros:</strong> ~620 kcal | 50P | 45C | 25G</p>
      <h4>Modo de Preparo:</h4>
      <ol><li>Tempere o salmão com limão e ervas. <li>Asse a 180°C por 12-15 min. <li>Cozinha batata doce e prepara salada.</li></ol>
    </div>

    <div class="card">
      <h3>🥜 Snack / Pós-Treino</h3>
      <p><strong>Recuperação Rápida:</strong> 200g iogurte grego, 1 maçã, 20g amêndoas, canela</p>
      <p><strong>Macros:</strong> ~320 kcal | 20P | 25C | 18G</p>
      <h4>Modo de Preparo:</h4>
      <ol><li>Coloca iogurte na taça. <li>Adiciona maçã cortada e amêndoas.</li></ol>
    </div>

    <div class="card">
      <h3>🍳 Outra Opção - Pequeno Almoço Proteico</h3>
      <p>4 ovos mexidos com espinafre, 100g aveia, 1 banana e whey (opcional)</p>
      <h4>Modo de Preparo:</h4>
      <p>Refoga espinafre, mexe os ovos, cozinha aveia e serve com banana.</p>
    </div>
  </section>

  <!-- EXERCÍCIOS COMPLETOS -->
  <section id="exercicios">
    <h2>💪 Exercícios para Todos os Músculos</h2>
    <div class="muscle-grid">
      <div class="exercise card"><h3>Peito</h3><p>Flexões • Flexões Diamante • Flexões Elevadas</p></div>
      <div class="exercise card"><h3>Ombros</h3><p>Pike Push-ups • Elevação Lateral (com garrafas) • Handstand Hold</p></div>
      <div class="exercise card"><h3>Costas</h3><p>Superman • Remada Invertida • Pull-ups (ou negativos)</p></div>
      <div class="exercise card"><h3>Bíceps</h3><p>Flexão de Braço com Toalha • Chin-ups</p></div>
      <div class="exercise card"><h3>Tríceps</h3><p>Flexões Diamante • Mergulhos em Banco</p></div>
      <div class="exercise card"><h3>Quadríceps / Pernas</h3><p>Agachamento Livre • Avanços • Pistol Squat (assistido)</p></div>
      <div class="exercise card"><h3>Glúteos</h3><p>Ponte de Glúteo • Hip Thrust • Donkey Kicks</p></div>
      <div class="exercise card"><h3>Abdómen</h3><p>Prancha • Abdominal Bicicleta • Leg Raises • Dragon Flag</p></div>
    </div>
  </section>

  <!-- CALCULADORA -->
  <section id="calculadora">
    <h2>🧮 Calculadoras</h2>
    
    <!-- IA Super Inteligente -->
    <div class="card">
      <h3>🔍 Calculadora IA de Refeições</h3>
      <textarea id="refeicaoInput" placeholder="Ex: 200g salmão, 150g arroz integral, brócolis, 1 banana"></textarea>
      <button onclick="analisarRefeicao()">Analisar com IA</button>
      <div id="resultadoIA" style="margin-top:20px; padding:15px; background:#111; border-radius:8px;"></div>
    </div>

    <!-- Calorias Diárias Pessoais -->
    <div class="card">
      <h3>📊 Calorias Diárias Pessoais</h3>
      <label>Sexo:</label><select id="sexo"><option value="masculino">Masculino</option><option value="feminino">Feminino</option></select>
      <label>Idade (anos):</label><input type="number" id="idade" value="25">
      <label>Peso (kg):</label><input type="number" id="peso" value="75">
      <label>Altura (cm):</label><input type="number" id="altura" value="175">
      <label>Atividade:</label>
      <select id="atividade">
        <option value="1.2">Sedentário</option>
        <option value="1.375" selected>Leve</option>
        <option value="1.55">Moderado</option>
        <option value="1.725">Intenso</option>
      </select>
      <button onclick="calcularCaloriasPessoais()">Calcular TDEE</button>
      <div id="resultadoPessoal" style="margin-top:20px; padding:15px; background:#1a1a1a;"></div>
    </div>
  </section>

  <!-- PLANO 12 SEMANAS -->
  <section id="plano">
    <h2>📅 Plano de Treino de 12 Semanas</h2>
    <div class="card">
      <table style="width:100%; border-collapse:collapse;">
        <tr><th>Semana</th><th>Foco</th><th>Treino</th><th>Dica</th></tr>
        <tr><td>1-4</td><td>Hipertrofia</td><td>3-4 dias peso corporal</td><td>Foco em técnica</td></tr>
        <tr><td>5-8</td><td>Força</td><td>Aumentar repetições</td><td>Pausas curtas</td></tr>
        <tr><td>9-12</td><td>Definição</td><td>HIIT + Circuito</td><td>Diminuir descanso</td></tr>
      </table>
    </div>
  </section>

  <!-- CLARK KENT MODE -->
  <section id="clark">
    <h2>🦸 Clark Kent Mode - Ativado</h2>
    <div class="card" style="text-align:center; font-size:1.4rem;">
      <p>Disciplina é o teu verdadeiro superpoder.</p>
      <p style="color:#ff3333;">"Smallville não te define. Suas escolhas definem você."</p>
    </div>
  </section>

  <footer style="text-align:center; padding:50px; background:#000; color:#ff6666;">
    Smallville Health Fortress © 2026
  </footer>

  <script>
    // Calculadora Pessoal
    function calcularCaloriasPessoais() {
      const sexo = document.getElementById('sexo').value;
      const idade = parseInt(document.getElementById('idade').value) || 25;
      const peso = parseFloat(document.getElementById('peso').value) || 75;
      const altura = parseFloat(document.getElementById('altura').value) || 175;
      const atividade = parseFloat(document.getElementById('atividade').value);

      let tmb = sexo === 'masculino' 
        ? 88.362 + (13.397 * peso) + (4.799 * altura) - (5.677 * idade)
        : 447.593 + (9.247 * peso) + (3.098 * altura) - (4.330 * idade);

      const tdee = Math.round(tmb * atividade);
      document.getElementById('resultadoPessoal').innerHTML = `
        <strong>TMB:</strong> ${Math.round(tmb)} kcal<br>
        <strong>Calorias Diárias Recomendadas:</strong> <span style="color:#ffd700;font-size:1.5rem;">${tdee} kcal</span>
      `;
    }

    // IA de Refeições
    const alimentosDB = {
      "banana": 89, "maçã": 52, "pera": 62, "laranja": 85, "morango": 50,
      "manga": 68, "abacaxi": 47, "abacate": 160,
      "frango": 165, "peito de frango": 165, "salmão": 200,
      "atum": 130, "bovina": 180, "porco": 200,
      "arroz": 130, "aveia": 95, "ovo": 78, "ovos": 78,
      "brócolis": 31, "espinafre": 23, "batata doce": 77,
      "pasta de amendoim": 580
    };

    function analisarRefeicao() {
      const texto = document.getElementById('refeicaoInput').value.toLowerCase().trim();
      if (!texto) return alert("Escreve tua refeição!");

      let total = 0;
      let lista = [];

      const partes = texto.split(/,| e |\+|;/).map(p => p.trim());

      partes.forEach(parte => {
        let qtd = 100;
        let nome = parte;

        const num = parte.match(/(\d+(?:\.\d+)?)/);
        if (num) qtd = parseFloat(num[0]);

        let cal = 0;
        for (let key in alimentosDB) {
          if (nome.includes(key)) {
            cal = alimentosDB[key];
            break;
          }
        }

        const calItem = Math.round((cal / 100) * qtd);
        total += calItem;
        lista.push(`• ${parte} → ${calItem} kcal`);
      });

      document.getElementById('resultadoIA').innerHTML = `
        <strong>Análise IA:</strong><br><br>
        ${lista.join('<br>')}<br><br>
        <strong style="color:#ffd700; font-size:1.7rem;">Total: ${total} kcal</strong>
      `;
    }
  </script>
</body>
</html>
